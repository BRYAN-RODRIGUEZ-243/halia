# Traccar API Configuration
TRACCAR_URL=https://tu-servidor-traccar.com
TRACCAR_USER=admin@traccar.com
TRACCAR_PASS=tu_contraseña_traccar

# JWT Secret (genera uno aleatorio con: openssl rand -base64 32)
JWT_SECRET=tu_secret_key_aqui_muy_segura_y_aleatoria

# PostgreSQL Database (para módulo de combustible, conductores, etc.)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/halia

# Opcional: URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000
