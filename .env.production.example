# ============================================
# HALIA - Production Environment Variables
# ============================================
# IMPORTANTE: Copia este archivo como .env.production y completa los valores
# NO subas .env.production a GitHub (ya está en .gitignore)

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_USER=halia
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA_SEGURA_ALEATORIA
POSTGRES_DB=halia

# ============================================
# Traccar GPS Server
# ============================================
TRACCAR_URL=https://your-traccar-server.com
TRACCAR_USER=your_email@example.com
TRACCAR_PASS=your_traccar_password

# ============================================
# JWT Authentication
# ============================================
# Genera uno aleatorio con: openssl rand -base64 32
JWT_SECRET=CAMBIA_ESTE_SECRET_ALEATORIO_MUY_SEGURO
JWT_EXPIRES_IN=8h

# ============================================
# Application Settings
# ============================================
# URL pública de tu aplicación (cambiar por tu dominio)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Puerto donde correrá la app (default: 3000)
APP_PORT=3000
